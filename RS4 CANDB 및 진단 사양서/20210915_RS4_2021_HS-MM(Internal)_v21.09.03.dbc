BA_ "RoutingFactor" SG_ 2395189761 DATC_Typ 1;
BA_ "Version" SG_ 2395189761 DATC_Typ "21.07.06";
BA_ "Description" SG_ 2395189761 DATC_Opt1Typ "Bit0 : (ADS) : 0 - Non ADS / 1 - ADS
Bit1 : (AQS) : 0 - Non AQS / 1 ? AQS
Bit2 : (MAX AC) : 0 - Non MAX AC / 1 - MAX AC
Bit3 : (SYNC) : 0 - Non SYNC / 1 - SYNC
Bit4 : (DUST) : 0 - Non AIR PURIFIER / 1 - AIR PURIFIER
Bit5 : (Smart_Vent) : 0 - Non SMART VENT / 1 ? SMART VENT
Bit6 : (CO2) : 0 - Non CO2 / 1 - CO2
Bit7 : (REAR LOCK) : 0 - NON REAR LOCK / 1 - REAR LOCK
HTR CONTROL OPTION";
BA_ "GenSigSendType" SG_ 2395189761 DATC_Opt1Typ 4;
BA_ "GenSigStartValue" SG_ 2395189761 DATC_Opt1Typ 0;
BA_ "UserSigValidity" SG_ 2395189761 DATC_Opt1Typ 3;
