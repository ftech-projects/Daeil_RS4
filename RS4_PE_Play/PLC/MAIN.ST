(* ===================================================================
   유격 검사기 PLC ST 제어 프로그램
   CPU  : Q04UDEHCPU (이더넷 내장)
   모션 : QD77MS2  ← 슬롯 번호에 따라 아래 표를 수정할 것

   [슬롯별 X/Y 기본 번지]
     슬롯 0 → X000~X01F  / Y000~Y01F  (U0)
     슬롯 1 → X020~X03F  / Y020~Y03F  (U1)
     슬롯 2 → X040~X05F  / Y040~Y05F  (U2)

   이 파일은 QD77MS2가 슬롯 0 (X0~/Y0~) 기준으로 작성됨.
   슬롯이 다르면 Y0→Y20 등으로 일괄 수정 필요.

   물리 입출력 (QX42/QY42P) 슬롯 번지도 현장 배선에 맞게 수정.
   이 파일에서는 QX42=슬롯2(X40~), QY42P=슬롯3(Y60~) 예시.

   [PC ↔ PLC D 레지스터 맵]
   PC 쓰기 (PC→PLC) :
     D4004.0  솔레노이드 클램프 지령
     D4009.0  플리커 (통신 감시)
     D4009.1  전진 JOG 지령
     D4009.2  후진 JOG 지령
     D4009.3  에러 리셋 지령
     D4009.8  PC 통신 정상
     D4009.9  서보 ON 지령
     D4012.0  포지션1 이동 지령
     D4012.1  포지션2 이동 지령
     D6000/1  포지션1 위치 (DINT 하위/상위)
     D6002/3  포지션1 속도 (DINT 하위/상위)
     D6004/5  포지션2 위치
     D6006/7  포지션2 속도
     D6008/9  포지션3 위치
     D6010/11 포지션3 속도
     D6012/13 포지션4 위치
     D6014/15 포지션4 속도
     D6032/33 포지션5 위치
     D6034/35 포지션5 속도
     D6036/37 포지션6 위치
     D6038/39 포지션6 속도
     D5002/3  JOG 속도 (DINT 하위/상위)

   PC 읽기 (PLC→PC) :
     D4000.0  PUSH 버튼
     D4000.1  리셋 버튼
     D4000.2  비상 버튼 (NC, 정상=ON)
     D4000.3  클램프 확인 센서
     D4000.4  언클램프 확인 센서
     D4000.5  LVDT 전진 완료 센서
     D4000.6  LVDT 후진 완료 센서
     D4000.7  LOAD 하강 완료 센서
     D4000.8  LOAD 상승 완료 센서
     D4008.1  서보 알람
     D4014.0  포지션1 이동 완료
     D4014.1  포지션2 이동 완료

   [보조 릴레이 사용]
     M0   PC 통신 정상 래치
     M1   비상 상태
     M10  포지션1 지령 이전값 (엣지 감지)
     M11  포지션2 지령 이전값 (엣지 감지)
     M20  포지션1 이동 진행중
     M21  포지션2 이동 진행중
   ================================================================= *)


(* ================================================================
   SECTION 1 : 물리 입력 → D4000 (PC가 MX Component로 읽는 영역)
   ← 실제 X 번지를 현장 배선에 맞게 수정
   ================================================================ *)
D4000.0 := X40;    (* PUSH 버튼 (NO) *)
D4000.1 := X41;    (* 리셋 버튼 (NO) *)
D4000.2 := X42;    (* 비상 버튼 (A접 — 정상 OFF / 비상 ON) *)
D4000.3 := X43;    (* 클램프 확인 센서 *)
D4000.4 := X44;    (* 언클램프 확인 센서 *)
D4000.5 := X45;    (* LVDT 전진 완료 센서 *)
D4000.6 := X46;    (* LVDT 후진 완료 센서 *)
D4000.7 := X47;    (* LOAD 하강 완료 센서 *)
D4000.8 := X48;    (* LOAD 상승 완료 센서 *)


(* ================================================================
   SECTION 2 : 비상 처리
   D4000.2 = A접: 비상 버튼 누름 → ON
   비상 시 전체 출력 강제 차단
   ================================================================ *)
IF D4000.2 THEN
    M1     := TRUE;
    Y60    := FALSE;   (* 솔레노이드 클램프 강제 OFF ← 실제 Y 번지로 수정 *)
    Y8     := FALSE;   (* 1축 JOG 정방향 OFF *)
    Y9     := FALSE;   (* 1축 JOG 역방향 OFF *)
    Y5     := FALSE;   (* 위치결정 시작 OFF *)
    M20    := FALSE;   (* 포지션1 이동 플래그 클리어 *)
    M21    := FALSE;
    D4014.0 := FALSE;
    D4014.1 := FALSE;
ELSE
    M1 := FALSE;
END_IF;


(* ================================================================
   SECTION 3 : PC 통신 정상 감시
   D4009.8 = PC가 매 사이클 갱신하는 통신 정상 플래그
   ================================================================ *)
M0 := D4009.8;    (* M0=1 : PC 통신 정상 *)


(* ================================================================
   SECTION 4 : QD77MS2 기본 제어
   Y0  : PLC READY (항상 ON)
   Y4  : 1축 서보 ON
   YA  : 1축 에러 리셋
   ← Y 번지는 QD77MS2 슬롯 기준. 슬롯1이면 Y20/Y24/Y2A 로 수정
   ================================================================ *)

(* PLC READY — 항상 ON *)
Y0 := TRUE;

(* 서보 ON: PC 지령 + 비상 없음 + PC 통신 정상 *)
IF D4009.9 AND NOT M1 AND M0 THEN
    Y4 := TRUE;
ELSE
    Y4 := FALSE;
END_IF;

(* 에러 리셋 펄스 전달 — gYA: 글로벌 라벨 BIT/YA *)
gYA := D4009.3;

(* 서보 알람 → D4008.1 (gXC = 1축 에러 검출, 슬롯0 기준) — gXC: 글로벌 라벨 BIT/XC *)
D4008.1 := gXC;


(* ================================================================
   SECTION 5 : 포지션 파라미터 전송
   PC가 D6000~ 에 쓴 위치/속도를 QD77MS2 위치결정 데이터 영역에 복사
   Da.6 목표 위치 (DINT 2워드), Da.8 속도 (DINT 2워드)
   위치결정 데이터 No. 당 10워드 간격:
     No.1 Base: U0\G4600  Da.6=G4604/G4605  Da.8=G4608/G4609
     No.2 Base: U0\G4610  Da.6=G4614/G4615  Da.8=G4618/G4619
     ...
   ← 버퍼 메모리 번지는 QD77MS2 매뉴얼 "위치결정 데이터" 참조
      제어 방식(Da.1)은 GX Works3 파라미터 설정 화면에서 별도 설정
   ================================================================ *)

(* No.1 — 검사 위치 *)
U0\G4604 := D6000;    (* 목표 위치 하위 워드 *)
U0\G4605 := D6001;    (* 목표 위치 상위 워드 *)
U0\G4608 := D6002;    (* 속도 하위 워드 *)
U0\G4609 := D6003;    (* 속도 상위 워드 *)

(* No.2 — 대기 위치 *)
U0\G4614 := D6004;
U0\G4615 := D6005;
U0\G4618 := D6006;
U0\G4619 := D6007;

(* No.3 *)
U0\G4624 := D6008;
U0\G4625 := D6009;
U0\G4628 := D6010;
U0\G4629 := D6011;

(* No.4 *)
U0\G4634 := D6012;
U0\G4635 := D6013;
U0\G4638 := D6014;
U0\G4639 := D6015;

(* No.5 *)
U0\G4664 := D6016;
U0\G4665 := D6017;
U0\G4668 := D6018;
U0\G4669 := D6019;

(* No.6 *)
U0\G4674 := D6020;
U0\G4675 := D6021;
U0\G4678 := D6022;
U0\G4679 := D6023;

(* JOG 속도 → Cd.17 (U0\G1534/G1535) *)
U0\G1534 := D5002;
U0\G1535 := D5003;


(* ================================================================
   SECTION 6 : JOG 운전 (전진 / 후진)
   서보 ON + 비상 없음 + 포지션 이동 중 아닐 때만 허용
   Y8 = 1축 정방향 JOG, Y9 = 1축 역방향 JOG (슬롯0 기준)
   ================================================================ *)
IF Y4 AND NOT M1 AND NOT M20 AND NOT M21 THEN
    IF D4009.1 THEN
        Y8 := TRUE;
        Y9 := FALSE;
    ELSIF D4009.2 THEN
        Y8 := FALSE;
        Y9 := TRUE;
    ELSE
        Y8 := FALSE;
        Y9 := FALSE;
    END_IF;
ELSE
    Y8 := FALSE;
    Y9 := FALSE;
END_IF;


(* ================================================================
   SECTION 7 : 포지션 이동 제어
   D4012.0 상승엣지 → No.1 위치결정 시작
   D4012.1 상승엣지 → No.2 위치결정 시작
   완료 (X5 = 1축 위치결정 완료) → D4014.0 / D4014.1
   Y5 = 위치결정 시작 펄스 (슬롯0, 1스캔 ON)
   X5 = 1축 위치결정 완료 (슬롯0 기준 ← 매뉴얼로 번지 재확인)
   ================================================================ *)

(* ── 포지션1 이동 ── *)
IF D4012.0 AND NOT M10         (* 상승엣지 *)
   AND Y4 AND NOT M1           (* 서보 ON + 비상 없음 *)
   AND NOT M20 AND NOT M21     (* 다른 포지션 이동 중 아님 *)
THEN
    U0\G1500 := 1;   (* Cd.190: 위치결정 No.1 선택 *)
    Y5  := TRUE;     (* 위치결정 시작 펄스 ON *)
    M20 := TRUE;     (* 이동 진행중 플래그 *)
    D4014.0 := FALSE;
END_IF;
M10 := D4012.0;     (* 이전값 저장 *)

(* ── 포지션2 이동 ── *)
IF D4012.1 AND NOT M11
   AND Y4 AND NOT M1
   AND NOT M20 AND NOT M21
THEN
    U0\G1500 := 2;
    Y5  := TRUE;
    M21 := TRUE;
    D4014.1 := FALSE;
END_IF;
M11 := D4012.1;

(* 시작 펄스 — 다음 스캔 OFF *)
IF M20 OR M21 THEN
    Y5 := FALSE;
END_IF;

(* 완료 감지 (X5 = 1축 위치결정 완료 ← 슬롯에 따라 X5/X25/X45 등으로 수정) *)
IF M20 AND X5 THEN
    D4014.0 := TRUE;
    M20     := FALSE;
END_IF;

IF M21 AND X5 THEN
    D4014.1 := TRUE;
    M21     := FALSE;
END_IF;

(* PC가 지령 해제 시 완료 비트 클리어 *)
IF NOT D4012.0 THEN D4014.0 := FALSE; END_IF;
IF NOT D4012.1 THEN D4014.1 := FALSE; END_IF;


(* ================================================================
   SECTION 8 : 물리 출력
   솔레노이드 클램프: D4004.0 → Y60 (비상 없음 조건)
   ← Y 번지는 QY42P 실제 슬롯 번지로 수정
   ================================================================ *)
IF NOT M1 THEN
    Y60 := D4004.0;
    Y61 := D4004.1;
    Y62 := D4004.2;
    Y63 := D4004.3;
    Y64 := D4004.4;
    Y65 := D4004.5;
    Y66 := D4004.6;
    Y67 := D4004.7;
    Y68 := D4004.8;
    Y69 := D4004.9;
    Y6A := D4004.10;
    Y6B := D4004.11;
    Y6C := D4004.12;
    Y6D := D4004.13;
    Y6E := D4004.14;
    Y6F := D4004.15;
END_IF;
