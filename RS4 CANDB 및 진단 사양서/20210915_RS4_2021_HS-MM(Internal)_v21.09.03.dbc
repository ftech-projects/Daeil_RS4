BA_ "RoutingFactor" SG_ 2223056129 SAS_AnglVal 5;
BA_ "Version" SG_ 2223056129 SAS_AnglVal "18.12.08";
BA_ "Description" SG_ 2223056129 SAS_SpdVal "Information regarding the steering wheel rotation speed 
(PH) = (HEX) * 4 (0 ˇÂ HEX < 254)";
BA_ "GenSigStartValue" SG_ 2223056129 SAS_SpdVal 255;
BA_ "UserSigValidity" SG_ 2223056129 SAS_SpdVal 3;
