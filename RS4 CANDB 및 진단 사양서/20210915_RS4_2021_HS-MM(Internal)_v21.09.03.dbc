BA_ "Description" SG_ 2164277250 TCU_EngTqLimVal "The TCU requests a engine torque limit(ETL) from the EMS. 
There is no time limitation of the intervention.
TCU requests engine torque limit below the TCU requesting torque.
The engine torque request signal means the absolute torque limitation.
TCU sends it through CAN system and makes it change every moment.
In any non-requesting situations, TCU sends the maximum value of CAN message.

If MSB is 1, this signal is - value.
else, this signal is +value.
0~10bit is used for absolute value.";
BA_ "GenSigStartValue" SG_ 2164277250 TCU_EngTqLimVal 2047;
BA_ "UserSigValidity" SG_ 2164277250 TCU_EngTqLimVal 3;
BA_ "NetworkRequestHoldingTime" SG_ 2164277250 TCU_EngTqLimVal 0;
BA_ "RoutingFactor" SG_ 2164277250 TCU_EngTqLimVal 5;
BA_ "Version" SG_ 2164277250 TCU_EngTqLimVal "18.01.02";
BA_ "Description" SG_ 2164277250 TCU_VehSpdKphVal "The vehicle speed calculated by TCU is transferred. 
If a vehicle has no vehicle speed sensor, no wheel speed sensor and no ABS(TCS/ESC) then it is impossible for an EMS to calculate veficle speed. In this case a TCU should calculate vehicle speed and send to other ECUs.
The calculation can be done with output speed of gearbox, final gear ratio and actual radius of a tire. 
In case of failure the value FFH is used as error identifier.";
BA_ "GenSigStartValue" SG_ 2164277250 TCU_VehSpdKphVal 0;
BA_ "UserSigValidity" SG_ 2164277250 TCU_VehSpdKphVal 3;
BA_ "NetworkRequestHoldingTime" SG_ 2164277250 TCU_VehSpdKphVal 0;
BA_ "RoutingFactor" SG_ 2164277250 TCU_VehSpdKphVal 5;
BA_ "Version" SG_ 2164277250 TCU_VehSpdKphVal "17.11.00";
BA_ "Description" SG_ 2164277250 TCU_TrgtGearSta "CF_Tcu_TarGr informs about the speed, which is currently engaged in the gearbox, or, in case of a gear change (SWI_GS), which speed is reached.

Note: Gear changes covering more than one speed are also possible.
In the P and N positions, the frictional connection is interrupted hydraulically.
Depending on the type of error, the 3rd or 4th (forward) speed, and the R (reverse) speed are engaged in the limp home program.";
BA_ "GenSigStartValue" SG_ 2164277250 TCU_TrgtGearSta 0;
BA_ "UserSigValidity" SG_ 2164277250 TCU_TrgtGearSta 3;
BA_REL_ "GenSigTimeoutTime" BU_SG_REL_ AMP SG_ 2164277250 TCU_TrgtGearSta 500;
BA_ "NetworkRequestHoldingTime" SG_ 2164277250 TCU_TrgtGearSta 0;
BA_ "RoutingFactor" SG_ 2164277250 TCU_TrgtGearSta 5;
BA_ "Version" SG_ 2164277250 TCU_TrgtGearSta "17.11.00";
BA_ "Description" SG_ 2164277250 TCU_DcmlVehSpdKphVal "The signal VS_TCU_DECIAMAL means the value which is below decimal point of the vehicle speed.
For instance, if a vehicle speed is 13.75Km/h, VS_TCU means 13Km/h and VS_TCU_DECIMAL means 0.75Km/h.

Example)   VS_TCU = 13,  VS_TCU_DECIAMAL  = 96
Vehicle speed  = VS_TCU + ( VS_TCU_DECIMAL / 128 )
= 13 + ( 96 / 128 ) = 13.75 [Km/h]";
BA_ "GenSigStartValue" SG_ 2164277250 TCU_DcmlVehSpdKphVal 0;
BA_ "UserSigValidity" SG_ 2164277250 TCU_DcmlVehSpdKphVal 3;
BA_ "NetworkRequestHoldingTime" SG_ 2164277250 TCU_DcmlVehSpdKphVal 0;
BA_ "RoutingFactor" SG_ 2164277250 TCU_DcmlVehSpdKphVal 5;
BA_ "Version" SG_ 2164277250 TCU_DcmlVehSpdKphVal "17.11.00";
BA_ "Description" SG_ 2164277250 TCU_SprkRtrdReq "The TCU requests a spark angle retard via the signal SPK_RTD_TCU to the EMS for torque reduction during the gear engage condition.

(PH) = ((HEX) - 3FH) * 0.375 (Advance) (PH) = (3FH - (HEX)) * (-0.375) (Retard)
-15˘Ş  ... 0˘Ş= 17H .. 3FH (Retard)
0.375˘Ş. 15˘Ş= 40H .. 67H (Advance)";
BA_ "GenSigStartValue" SG_ 2164277250 TCU_SprkRtrdReq 255;
BA_ "UserSigValidity" SG_ 2164277250 TCU_SprkRtrdReq 3;
BA_ "NetworkRequestHoldingTime" SG_ 2164277250 TCU_SprkRtrdReq 0;
BA_ "RoutingFactor" SG_ 2164277250 TCU_SprkRtrdReq 5;
BA_ "Version" SG_ 2164277250 TCU_SprkRtrdReq "17.11.00";
