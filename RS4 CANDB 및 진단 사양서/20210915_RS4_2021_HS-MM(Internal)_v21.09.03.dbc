BA_ "Description" SG_ 2479160833 HU_OptionInfo "Bit0 : Navi (0: Not Support / 1: Support)
Bit1 : USM (0: Not Support / 1: Support)
Bit2 : TMS (0: Not Support / 1: Support)
Bit3 : Multi Profile (0: Not Support(No Profile or Single Profile)  / 1: Support)
Bit4 : Camera Guideline (0: Displayed by Camera / 1: Displayed by H/U)
Bit5 : LVDS Interface (0:MIPI, 1:Non-MIPI)
Bit6 : Welcome/Goodbye Animation Support (0: Not Support / 1: Support)
Bit7 : Drive/Custom Mode Support (0: Not Support / 1 : Support)
Bit8 : Automatic brightness adjustment function Support (0: Not Support / 1 : Support) 
Bit9~Bit14 : Reserved
Bit15 : Invalid";
BA_ "GenSigSendType" SG_ 2479160833 HU_OptionInfo 4;
