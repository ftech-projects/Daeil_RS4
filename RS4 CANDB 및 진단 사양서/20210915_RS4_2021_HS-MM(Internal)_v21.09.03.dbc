BA_ "Description" SG_ 2479160833 HU_AdasSupport "0x0 : Not Support
0x1 : ADAS Support (General Map) - Send map information based on General Map
0x2 : ADAS Support (Map based ADAS v1) - Send map information based on Map based ADAS v1 or v1.5
0x3 : ADAS Support (Map based ADAS v2) - Send map information based on Map based ADAS v2.0
0x4 : ADAS Support (Map based ADAS v2.0 & Handshaking) - Send map information based on Map based ADAS v2.0 & Support Handshaking 
0x5 : ADAS Support (Map based ADAS v2.3)  
 - 2nd CAN DB :  Send map information based on Map based ADAS v2.3 
 - 3rd CAN DB : Send map information based on Map based ADAS v2.3 & Support Handshaking";
BA_ "GenSigSendType" SG_ 2479160833 HU_AdasSupport 4;
BA_ "GenSigStartValue" SG_ 2479160833 HU_AdasSupport 7;
BA_ "UserSigValidity" SG_ 2479160833 HU_AdasSupport 1;
BA_ "NetworkRequest" SG_ 2479160833 HU_AdasSupport 0;
BA_ "NetworkRequestHoldingTime" SG_ 2479160833 HU_AdasSupport 5000;
BA_ "RoutingFactor" SG_ 2479160833 HU_AdasSupport 1;
BA_ "Version" SG_ 2479160833 HU_AdasSupport "20.05.02";
BA_ "Description" SG_ 2479160833 HU_Navi_RspADASMapMsg "This signal indicates an ADAS map message response from H_U to ECU 
which is stored the  required Map based ADAS messages for each ECU

Each bit indicates the request messages as follows.
(1: Sending message / 0 : Doens't sending message)
- Bit 0 : H_U_NAVI_V2_STUB_E
- Bit 1 : HU_NAVI_V2_PROSHORT_E_00 (Curvature info)
- Bit 2 : HU_NAVI_V2_PROSHORT_E_00 (Info execpt curvature)
- Bit 3 : HU_NAVI_V2_PROSHORT_E_01
- Bit 4 : HU_NAVI_V2_PROSHORT_E_02
- Bit 5 : HU_NAVI_V2_PROLONG_E
- Bit 6 : HU_NAVI_V2_SEG_SUB_E, 
             HU_NAVI_V2_STUB_SUB_E, 
             HU_NAVI_V2_PROSHORT_SUB_E, 
             HU_NAVI_V2_PROLONG_SUB_E
- Bit 7 : HU_NAVI_V2_PATH_PE_00, 
             HU_NAVI_V2_PATH_PE_01
- Bit 8~15 : Reserved";
BA_ "GenSigSendType" SG_ 2479160833 HU_Navi_RspADASMapMsg 4;
BA_ "GenSigStartValue" SG_ 2479160833 HU_Navi_RspADASMapMsg 0;
BA_ "UserSigValidity" SG_ 2479160833 HU_Navi_RspADASMapMsg 3;
BA_ "NetworkRequestHoldingTime" SG_ 2479160833 HU_Navi_RspADASMapMsg 0;
BA_ "RoutingFactor" SG_ 2479160833 HU_Navi_RspADASMapMsg 1;
BA_ "Version" SG_ 2479160833 HU_Navi_RspADASMapMsg "19.09.06";
