BA_ "GenMsgStartDelayTime" BO_ 1127 0;
BA_ "Description" SG_ 1127 DPSS_Crc1Val "The data area for CRC calculation is based on the data length (DLC) of the message DB.
The CRC shall be calculated over the entire data block (excluding the CRC bytes) including the user data, alive counter and Data ID 
 
- CRC Polynomial (0x1D) , Initial Value : 0x00, XOR value : 0xFF, Data ID Mode : Both, Data ID : Message ID + 0xF800 
- The initial value is for CRC calculation and the message should be sent with the calculated result value. 
The mathematical expression to 8 bit CRC polynomial is given here. G(x) = x8 + x4 + x3 + x2 + 1";
BA_ "GenSigSendType" SG_ 1127 DPSS_Crc1Val 4;
BA_ "GenSigStartValue" SG_ 1127 DPSS_Crc1Val 255;
BA_ "UserSigValidity" SG_ 1127 DPSS_Crc1Val 0;
BA_REL_ "GenSigTimeoutTime" BU_SG_REL_ PSM SG_ 1127 DPSS_Crc1Val 1500;
BA_ "NetworkRequestHoldingTime" SG_ 1127 DPSS_Crc1Val 0;
BA_ "RoutingFactor" SG_ 1127 DPSS_Crc1Val 1;
BA_ "Version" SG_ 1127 DPSS_Crc1Val "19.01.01";
