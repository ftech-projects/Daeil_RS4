BA_ "RoutingFactor" SG_ 2395189761 DATC_Opt3Typ 1;
BA_ "Version" SG_ 2395189761 DATC_Opt3Typ "21.07.06";
BA_ "Description" SG_ 2395189761 DATC_Opt2Typ "Bit0 : (FRONT BLOWER) : 0 - SINGLE BLOWER / 1 ? DUAL BLOWER
Bit1 : (FRONT AUTO ZONE) : 0 - SINGLE AUTO / 1 - DUAL AUTO
Bit2 : (LCD / NON LCD TYPE) : 0 - NON LCD /  1 - LCD TYPE
Bit3 : (INDIRECT VENT) : 0 - NON INDIRECT VENT /  1 - INDIRECT VENT
HTR CONTROL OPTION";
BA_ "GenSigSendType" SG_ 2395189761 DATC_Opt2Typ 4;
BA_ "GenSigStartValue" SG_ 2395189761 DATC_Opt2Typ 0;
BA_ "UserSigValidity" SG_ 2395189761 DATC_Opt2Typ 3;
