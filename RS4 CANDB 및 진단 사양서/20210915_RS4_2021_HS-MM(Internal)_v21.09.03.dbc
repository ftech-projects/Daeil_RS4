BA_ "Description" SG_ 2239849730 PA_Sta "This signal indicates the status of the PA steering activation machine. 

 <Fuction>
0H : Reserved
1H : Initial value after ignition
2H : Request of a new start status after an abort of the MDPS
3H : StandBy status of the PA function. No error and no request
4H : First request toward an automatic steering
5H : Final request for an automatic steering
6H : Acknowledge an MDPS failure. This state is set for one cycle only
7H : Acknowledge an MDPS abort. This state is set for one cycle only
8H ~ FH : Reserved";
BA_ "GenSigStartValue" SG_ 2239849730 PA_Sta 1;
BA_ "UserSigValidity" SG_ 2239849730 PA_Sta 3;
BA_ "NetworkRequestHoldingTime" SG_ 2239849730 PA_Sta 0;
BA_ "RoutingFactor" SG_ 2239849730 PA_Sta 5;
BA_ "Version" SG_ 2239849730 PA_Sta "17.12.03";
