BA_ "Description" SG_ 2223056129 SAS_Crc1Val "The data area for CRC calculation is based on the data length (DLC) of the message DB.
The CRC shall be calculated over the entire data block (excluding the CRC bytes) including the user data, alive counter and Data ID
 
- CRC Polynomial (0x1021) , Initial Value : 0xFFFF, XOR value : 0x0000, Data ID : Message ID + 0xF800 
- The initial value is for CRC calculation and the message should be sent with the calculated result value. 
- The mathematical expression to 16 bit CRC polynomial is given here. G(x) = x16 + x12 + x5 + 1";
BA_ "GenSigStartValue" SG_ 2223056129 SAS_Crc1Val 65535;
BA_ "UserSigValidity" SG_ 2223056129 SAS_Crc1Val 3;
BA_ "NetworkRequestHoldingTime" SG_ 2223056129 SAS_Crc1Val 0;
BA_ "RoutingFactor" SG_ 2223056129 SAS_Crc1Val 5;
BA_ "Version" SG_ 2223056129 SAS_Crc1Val "18.11.08";
BA_ "Description" SG_ 2223056129 SAS_AlvCnt1Val "For the first transmission request for a data element the counter shall be initialized with 0 and shall be incremented by 1 for every subsequent send request. 
When the counter reaches the maximum value(0xFF), then it shall restart with 0 for the next send request";
BA_ "GenSigStartValue" SG_ 2223056129 SAS_AlvCnt1Val 0;
BA_ "UserSigValidity" SG_ 2223056129 SAS_AlvCnt1Val 3;
BA_ "NetworkRequestHoldingTime" SG_ 2223056129 SAS_AlvCnt1Val 0;
BA_ "RoutingFactor" SG_ 2223056129 SAS_AlvCnt1Val 5;
BA_ "Version" SG_ 2223056129 SAS_AlvCnt1Val "18.11.08";
BA_ "Description" SG_ 2223056129 SAS_AnglVal "Information regarding the steering wheel angle.  (PH) = (HEX) * 0.1 (0 <  HEX < 7FFFH) or (PH) = (HEX - 65536) * 0.1 (HEX > 7FFFH)";
BA_ "GenSigStartValue" SG_ 2223056129 SAS_AnglVal 32767;
BA_ "UserSigValidity" SG_ 2223056129 SAS_AnglVal 3;
BA_REL_ "GenSigTimeoutTime" BU_SG_REL_ ICC SG_ 2223056129 SAS_AnglVal 500;
