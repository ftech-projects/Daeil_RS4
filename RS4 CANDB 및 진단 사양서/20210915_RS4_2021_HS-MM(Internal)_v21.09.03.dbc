BA_ "Description" SG_ 2395189761 DATC_Typ "HTR CONTROL TYPE
Bit0 (FR Control) : 0 ? ATC / 1 ? MTC
Bit1~2 (Temp) : 0 ? Single / 1 ? Dual / 2 ? 3Zone / 3 ? 4Zone
Bit3~4 (Mode) : 0 ? Single / 1 ? Dual / 2 ? 3Zone / 3 ? 4Zone
Bit5 (Rear Control) : 0 ? None or MTC / 1- ATC
Bit6 (RHD) : 0 ? LHD / 1 ? RHD
Bit7 (EU) : 0 ? Others / 1 ? EU";
BA_ "GenSigSendType" SG_ 2395189761 DATC_Typ 4;
BA_ "GenSigStartValue" SG_ 2395189761 DATC_Typ 0;
BA_ "UserSigValidity" SG_ 2395189761 DATC_Typ 3;
